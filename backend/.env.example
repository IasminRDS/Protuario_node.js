# ============================================================
# Prontuário Eletrônico E2 — variáveis de ambiente
# Copie para .env e ajuste. NUNCA versione o .env (cap. 184).
# ============================================================

# Ambiente: development | homologation | production (cap. 163)
NODE_ENV=development
PORT=3000

# Banco de dados PostgreSQL (Prisma)
DATABASE_URL="postgresql://prontuario:prontuario@localhost:5432/prontuario_e2?schema=public"

# ------------------------------------------------------------
# RLS (Row-Level Security) — Fase 1. Rollout em 2 PASSOS:
#  1) Aplicar a migration 20260705000000_rls_phase1 (cria a role prontuario_app
#     + policies). Enquanto DATABASE_URL apontar para a role DONA (prontuario),
#     o RLS fica DORMENTE (owner bypassa RLS) — nada muda no comportamento.
#  2) ATIVAR enforcement: com os testes rls-phase1.e2e-spec.ts VERDES, defina
#     RLS_ENABLED=true e troque DATABASE_URL para a role prontuario_app (abaixo).
#  As migrations/seed continuam rodando na role dona (prontuario).
#  NUNCA faça (2) sem os testes verdes: se o pin de leitura falhar, o app lê vazio.
# ------------------------------------------------------------
RLS_ENABLED=false
# URL do app com a role NÃO-dona (usar SOMENTE no passo 2):
# DATABASE_URL="postgresql://prontuario_app:prontuario_app@localhost:5432/prontuario_e2?schema=public"
# Com RLS ativo, defina TAMBÉM a conexão de manutenção (role DONA) — usada
# pelo refresh das materialized views e pelo pg_dump (exigem ownership):
# MAINTENANCE_DATABASE_URL="postgresql://prontuario:prontuario@localhost:5432/prontuario_e2?schema=public"

# JWT (autenticação — cap. 147/148). Gere segredos fortes e distintos.
JWT_ACCESS_SECRET="troque-por-um-segredo-forte-de-access"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="troque-por-um-segredo-forte-de-refresh"
JWT_REFRESH_EXPIRES_IN="7d"

# Segurança
BCRYPT_OR_ARGON=argon2
LOGIN_MAX_ATTEMPTS=5

# MFA (TOTP RFC 6238). Step-up nas rotas de export/backup: perfis
# administrativos (SuperAdmin/Administrador/Gestor) precisam de MFA ativo e
# sessão verificada por código. Desligue APENAS em teste/CI.
MFA_ENFORCE_EXPORT=true

# --- Login gov.br (OIDC) ---
GOVBR_ENABLED=true
# SIMULATOR=true usa o IdP embutido (dev/homolog). Em produção, false + as
# URLs/credenciais do sso.acesso.gov.br.
GOVBR_SIMULATOR=true
GOVBR_CLIENT_ID=snpe-dev
GOVBR_AUTHORIZE_URL=
GOVBR_TOKEN_URL=
GOVBR_USERINFO_URL=
GOVBR_FRONTEND_URL=http://localhost:3001/login

# --- Assinatura digital de documentos (item 2) ---
# Chave privada PEM para assinar PDFs. Em produção use um certificado
# ICP-Brasil (A1/A3). Sem valor, gera par RSA efêmero (dev).
# DOC_SIGNING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Base da página pública de verificação (QR do PDF aponta p/ <base>/<docId>).
DOC_VERIFY_URL=http://localhost:3001/verificar

# CORS (origens permitidas, separadas por vírgula)
CORS_ORIGINS="http://localhost:3001"

# Rate limiting global (cap. 157). ATENÇÃO: no @nestjs/throttler v6 o ttl é em
# MILISSEGUNDOS. Ajuste conforme a versão em uso.
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# --- Exportação de pacientes (LGPD) ---
# Volume máximo de linhas por export (corte de abuso/OOM).
EXPORT_MAX_ROWS=100000
# Timeout do stream de export em ms (0 = desligado).
EXPORT_TIMEOUT_MS=300000
# Rate limit específico do export (mais restrito que o global). ttl em ms.
EXPORT_THROTTLE_LIMIT=10
EXPORT_THROTTLE_TTL_MS=60000

# --- Backup (pg_dump, somente SuperAdmin) ---
# Caminho do binário pg_dump (se não estiver no PATH).
PG_DUMP_PATH=pg_dump
# Timeout do pg_dump em ms e teto de bytes do arquivo gerado.
BACKUP_TIMEOUT_MS=600000
BACKUP_MAX_BYTES=2147483648
# Rate limit do backup (bem restrito — operação pesada e global). ttl em ms.
BACKUP_THROTTLE_LIMIT=3
BACKUP_THROTTLE_TTL_MS=300000

# Backbone de eventos (SNPE). false => adapter de log (mock substituível).
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=snpe-mpi

# Outbox worker (publisher por polling)
OUTBOX_POLL_INTERVAL_MS=2000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_STALE_CLAIM_MS=60000
OUTBOX_RETENTION_HOURS=168

# Seed inicial do administrador
SEED_ADMIN_LOGIN=admin
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_NOME="Administrador do Sistema"
